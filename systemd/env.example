# /etc/rustifymyclaw/env — API tokens and secrets
# Permissions: chmod 600 /etc/rustifymyclaw/env
#
# Optional: Override the default configuration path (/etc/rustifymyclaw/config.yaml)
# RUSTIFYMYCLAW_CONFIG=/custom/path/to/config.yaml
#
# Uncomment and set the variables your channels require:
# TELEGRAM_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
# WHATSAPP_TOKEN=
